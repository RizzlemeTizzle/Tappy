generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model for authentication and payment info
model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  name                String
  passwordHash        String    @map("password_hash")
  paymentMethodAdded  Boolean   @default(false) @map("payment_method_added")
  paymentMethodLast4  String?   @map("payment_method_last4")
  ocpiTokenUid        String?   @unique @map("ocpi_token_uid") // OCPI token for remote start
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  sessions                Session[]
  payments                Payment[]
  ocpiTokens              OcpiToken[]
  rfidTokens              RfidToken[]
  nfcTokens               NfcToken[]
  notificationPreference  NotificationPreference?
  favorites               FavoriteStation[]
  alertRequests           AvailabilityAlertRequest[]

  expoPushToken String? @map("expo_push_token")

  @@map("users")
}

// Station model
model Station {
  id        String    @id @default(uuid())
  name      String
  address   String
  latitude  Float
  longitude Float
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  chargers      Charger[]
  pricingPlan   PricingPlan?
  sessions      Session[]
  favoritedBy   FavoriteStation[]
  alertRequests AvailabilityAlertRequest[]

  @@index([latitude, longitude])
  @@map("stations")
}

// Charger model
model Charger {
  id              String    @id @default(uuid())
  stationId       String    @map("station_id")
  connectorType   String    @map("connector_type") // CCS, CHAdeMO, Type2
  maxKw           Float     @map("max_kw")
  status          String    @default("AVAILABLE") // AVAILABLE, CHARGING, COMPLETE, FAULTED
  nfcPayload      String    @unique @map("nfc_payload")
  ocpiEvseUid     String?   @unique @map("ocpi_evse_uid") // OCPI EVSE ID
  ocpiConnectorId String?   @map("ocpi_connector_id")
  currentSessionId String?  @map("current_session_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  station  Station   @relation(fields: [stationId], references: [id], onDelete: Cascade)
  sessions Session[]

  @@map("chargers")
}

// Pricing Plan model
model PricingPlan {
  id                    String   @id @default(uuid())
  stationId             String   @unique @map("station_id")
  startFeeCents         Int      @default(100) @map("start_fee_cents")
  energyRateCentsPerKwh Int      @default(35) @map("energy_rate_cents_per_kwh")
  taxPercent            Float    @default(21.0) @map("tax_percent")

  // Penalty/idle fee configuration
  penaltyEnabled           Boolean @default(true) @map("penalty_enabled")
  penaltyGraceMinutes      Int     @default(30) @map("penalty_grace_minutes")
  penaltyCentsPerMinute    Int     @default(50) @map("penalty_cents_per_minute")
  penaltyDailyCapCents     Int?    @map("penalty_daily_cap_cents")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@map("pricing_plans")
}

// Charging Session model
model Session {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  chargerId    String   @map("charger_id")
  stationId    String   @map("station_id")
  status       String   @default("PENDING") // PENDING, CHARGING, COMPLETE, IDLE, ENDED

  // OCPI-related fields
  ocpiSessionId   String?   @unique @map("ocpi_session_id")
  ocpiStatus      String?   @map("ocpi_status") // OCPI session status
  ocpiCommandId   String?   @map("ocpi_command_id")

  // Pricing snapshot (locked at session start)
  pricingStartFeeCents      Int @map("pricing_start_fee_cents")
  pricingEnergyRateCents    Int @map("pricing_energy_rate_cents")
  pricingTaxPercent         Float @map("pricing_tax_percent")
  pricingPenaltyEnabled     Boolean @map("pricing_penalty_enabled")
  pricingPenaltyGraceMin    Int @map("pricing_penalty_grace_min")
  pricingPenaltyCentsPerMin Int @map("pricing_penalty_cents_per_min")
  pricingPenaltyCapCents    Int? @map("pricing_penalty_cap_cents")

  // Meter readings
  meterStartKwh Float @default(0) @map("meter_start_kwh")
  meterEndKwh   Float @default(0) @map("meter_end_kwh")
  deliveredKwh  Float @default(0) @map("delivered_kwh")
  currentPowerKw Float @default(0) @map("current_power_kw")
  batteryPercent Int? @map("battery_percent")

  // Timing
  startedAt          DateTime? @map("started_at")
  endedAt            DateTime? @map("ended_at")
  chargingCompleteAt DateTime? @map("charging_complete_at")

  // Cost calculations
  penaltyMinutes    Int @default(0) @map("penalty_minutes")
  penaltyCostCents  Int @default(0) @map("penalty_cost_cents")
  energyCostCents   Int @default(0) @map("energy_cost_cents")
  taxCents          Int @default(0) @map("tax_cents")
  totalCostCents    Int @default(0) @map("total_cost_cents")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User     @relation(fields: [userId], references: [id])
  charger  Charger  @relation(fields: [chargerId], references: [id])
  station  Station  @relation(fields: [stationId], references: [id])
  payments Payment[]
  ocpiCdrs OcpiCdr[]

  @@index([userId])
  @@index([chargerId])
  @@map("sessions")
}

// Payment model
model Payment {
  id                   String   @id @default(uuid())
  sessionId            String   @map("session_id")
  userId               String   @map("user_id")
  amountCents          Int      @map("amount_cents")
  status               String   @default("PENDING") // PENDING, COMPLETED, FAILED
  stripePaymentIntentId String? @map("stripe_payment_intent_id")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  session Session @relation(fields: [sessionId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@map("payments")
}

// OCPI Token model - tokens issued to users for remote start
model OcpiToken {
  id            String   @id @default(uuid())
  uid           String   @unique // Token UID for OCPI
  type          String   @default("RFID") // RFID, APP_USER, OTHER
  authId        String   @map("auth_id") // Reference to user
  visualNumber  String?  @map("visual_number")
  issuer        String   @default("Tappy Charge")
  groupId       String?  @map("group_id")
  valid         Boolean  @default(true)
  whitelist     String   @default("ALWAYS") // ALWAYS, ALLOWED, ALLOWED_OFFLINE, NEVER
  lastUpdated   DateTime @default(now()) @map("last_updated")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id])

  @@map("ocpi_tokens")
}

// OCPI Command model - tracks start/stop commands
model OcpiCommand {
  id              String   @id @default(uuid())
  type            String   // START_SESSION, STOP_SESSION, RESERVE_NOW, etc.
  locationId      String   @map("location_id")
  evseUid         String?  @map("evse_uid")
  connectorId     String?  @map("connector_id")
  tokenUid        String?  @map("token_uid")
  sessionId       String?  @map("session_id")
  responseUrl     String?  @map("response_url")
  status          String   @default("PENDING") // PENDING, ACCEPTED, REJECTED, UNKNOWN, TIMEOUT
  result          String?  // Result from CPO
  retryCount      Int      @default(0) @map("retry_count")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([sessionId])
  @@map("ocpi_commands")
}

// OCPI CDR (Charge Detail Record) - final billing record
model OcpiCdr {
  id              String   @id @default(uuid())
  cdrId           String   @unique @map("cdr_id") // OCPI CDR ID
  sessionId       String   @map("session_id")
  startDateTime   DateTime @map("start_date_time")
  endDateTime     DateTime @map("end_date_time")
  totalKwh        Float    @map("total_kwh")
  totalParkingTime Float   @map("total_parking_time") // in hours
  totalCost       Float    @map("total_cost")
  currency        String   @default("EUR")
  authMethod      String   @default("AUTH_REQUEST") @map("auth_method")
  cpoId           String   @map("cpo_id")
  locationId      String   @map("location_id")
  evseUid         String   @map("evse_uid")
  connectorId     String   @map("connector_id")
  meterId         String?  @map("meter_id")
  rawCdr          Json?    @map("raw_cdr")
  createdAt       DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id])

  @@map("ocpi_cdrs")
}

// OCPI Location cache - stores CPO location data
model OcpiLocation {
  id            String   @id @default(uuid())
  locationId    String   @unique @map("location_id")
  cpoId         String   @map("cpo_id")
  name          String
  address       String
  city          String
  country       String
  latitude      Float
  longitude     Float
  evses         Json     // Array of EVSE data
  lastUpdated   DateTime @default(now()) @map("last_updated")
  rawLocation   Json?    @map("raw_location")

  @@index([latitude, longitude])
  @@map("ocpi_locations")
}

// CPO (Charge Point Operator) credentials
model OcpiCpoCredential {
  id              String   @id @default(uuid())
  partyId         String   @map("party_id")
  countryCode     String   @map("country_code")
  name            String
  businessDetails Json?    @map("business_details")
  url             String   // Base URL for OCPI endpoints
  token           String   // Token for authentication
  tokenC          String?  @map("token_c") // Our token for this CPO
  status          String   @default("ACTIVE") // ACTIVE, INACTIVE, PENDING
  versionsUrl     String?  @map("versions_url")
  endpoints       Json?    // Available OCPI module endpoints
  lastUpdated     DateTime @default(now()) @map("last_updated")
  createdAt       DateTime @default(now()) @map("created_at")

  tokenConfigs    CpoTokenConfig[]

  @@unique([partyId, countryCode])
  @@map("ocpi_cpo_credentials")
}

// ==================== RFID TOKEN MANAGEMENT ====================

// RFID Token model - physical charging cards/tags
model RfidToken {
  id              String    @id @default(uuid())
  uid             String    @unique // RFID UID from physical card (e.g., "04:A2:B3:C4:D5:E6:F7")
  contractId      String    @unique @map("contract_id") // Human-readable ID (e.g., "CTP-NL-2025-000001")
  visualNumber    String?   @map("visual_number") // Masked number for display
  type            String    @default("RFID") // RFID, AD_HOC_USER, APP_USER, OTHER
  status          String    @default("ACTIVE") // ACTIVE, BLOCKED, EXPIRED, PENDING
  whitelist       String    @default("ALWAYS") // ALWAYS, ALLOWED, ALLOWED_OFFLINE, NEVER
  
  // User association
  userId          String?   @map("user_id")
  user            User?     @relation(fields: [userId], references: [id])
  
  // OCPI fields
  issuer          String    @default("Tappy Charge")
  groupId         String?   @map("group_id") // For corporate/fleet grouping
  language        String?   @default("nl") // ISO 639-1
  
  // Validity
  validFrom       DateTime  @default(now()) @map("valid_from")
  validUntil      DateTime? @map("valid_until") // null = no expiry
  
  // Metadata
  lastUsedAt      DateTime? @map("last_used_at")
  usageCount      Int       @default(0) @map("usage_count")
  lastUpdated     DateTime  @default(now()) @map("last_updated")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  // Relations
  auditLogs       TokenAuditLog[]
  authorizations  TokenAuthorization[]

  @@index([userId])
  @@index([status])
  @@index([contractId])
  @@map("rfid_tokens")
}

// Token Audit Log - tracks all changes to tokens
model TokenAuditLog {
  id          String   @id @default(uuid())
  tokenId     String   @map("token_id")
  token       RfidToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  
  action      String   // CREATED, UPDATED, BLOCKED, UNBLOCKED, ASSIGNED, UNASSIGNED, EXPIRED, USED
  field       String?  // Which field was changed (for UPDATED)
  oldValue    String?  @map("old_value")
  newValue    String?  @map("new_value")
  
  performedBy String?  @map("performed_by") // Admin user or system
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  reason      String?  // Optional reason for the action
  
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tokenId])
  @@index([createdAt])
  @@map("token_audit_logs")
}

// Token Authorization - tracks authorization requests from CPOs
model TokenAuthorization {
  id              String   @id @default(uuid())
  tokenId         String   @map("token_id")
  token           RfidToken @relation(fields: [tokenId], references: [id])
  
  cpoPartyId      String   @map("cpo_party_id")
  cpoCountryCode  String   @map("cpo_country_code")
  locationId      String?  @map("location_id")
  evseUid         String?  @map("evse_uid")
  
  result          String   // ALLOWED, BLOCKED, EXPIRED, NO_CREDIT, NOT_ALLOWED, UNKNOWN
  responseTime    Int?     @map("response_time") // in milliseconds
  
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([tokenId])
  @@index([createdAt])
  @@map("token_authorizations")
}

// CPO Token Configuration - per-CPO settings for token access
model CpoTokenConfig {
  id              String   @id @default(uuid())
  cpoCredentialId String   @map("cpo_credential_id")
  cpoCredential   OcpiCpoCredential @relation(fields: [cpoCredentialId], references: [id], onDelete: Cascade)
  
  // Allowed token types this CPO can query
  allowedTypes    String[] @default(["RFID", "APP_USER"]) @map("allowed_types")
  
  // Rate limiting
  rateLimit       Int      @default(100) @map("rate_limit") // requests per minute
  rateLimitWindow Int      @default(60) @map("rate_limit_window") // seconds
  
  // IP allowlist (empty = allow all)
  ipAllowlist     String[] @default([]) @map("ip_allowlist")
  
  // Feature flags
  realTimeAuth    Boolean  @default(true) @map("real_time_auth") // Allow POST /authorize
  pullTokens      Boolean  @default(true) @map("pull_tokens") // Allow GET /tokens
  pushUpdates     Boolean  @default(false) @map("push_updates") // Push token updates to CPO
  
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([cpoCredentialId])
  @@map("cpo_token_configs")
}

// ==================== NFC HCE TOKEN MANAGEMENT ====================

// NFC Token model - Phone-as-card HCE tokens
model NfcToken {
  id              String    @id @default(uuid())
  
  // Token identifiers (8-byte hex format for RFID compatibility)
  uid             String    @unique // HCE token UID (e.g., "43541A2B3C4D5E6F")
  contractId      String    @unique @map("contract_id") // Human-readable ID
  visualNumber    String?   @map("visual_number") // Masked display number
  
  // Type and status
  type            String    @default("HCE") // HCE, APP_USER
  status          String    @default("ACTIVE") // ACTIVE, BLOCKED, EXPIRED, PENDING
  whitelist       String    @default("ALWAYS") // ALWAYS, ALLOWED
  
  // User and device binding
  userId          String    @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId        String    @map("device_id") // Android device ID for binding
  deviceModel     String?   @map("device_model")
  androidVersion  String?   @map("android_version")
  
  // HCE specific
  hceEnabled      Boolean   @default(false) @map("hce_enabled")
  isActive        Boolean   @default(false) @map("is_active") // Currently selected token
  
  // Token rotation
  rotationEnabled Boolean   @default(false) @map("rotation_enabled")
  previousUid     String?   @map("previous_uid") // For grace period
  rotatedAt       DateTime? @map("rotated_at")
  expiresAt       DateTime? @map("expires_at") // For rotation grace period
  
  // Usage tracking
  lastTapAt       DateTime? @map("last_tap_at")
  tapCount        Int       @default(0) @map("tap_count")
  lastLocation    String?   @map("last_location") // Last known tap location
  
  // OCPI fields
  issuer          String    @default("Tappy Charge")
  language        String?   @default("nl")
  
  // Timestamps
  lastUpdated     DateTime  @default(now()) @map("last_updated")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  // Relations
  auditLogs       NfcTokenAuditLog[]
  authorizations  NfcTokenAuthorization[]

  @@index([userId])
  @@index([deviceId])
  @@index([status])
  @@map("nfc_tokens")
}

// NFC Token Audit Log
model NfcTokenAuditLog {
  id          String    @id @default(uuid())
  tokenId     String    @map("token_id")
  token       NfcToken  @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  
  action      String    // CREATED, ACTIVATED, DEACTIVATED, BLOCKED, ROTATED, TAPPED
  field       String?
  oldValue    String?   @map("old_value")
  newValue    String?   @map("new_value")
  
  deviceInfo  String?   @map("device_info")
  ipAddress   String?   @map("ip_address")
  
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([tokenId])
  @@index([createdAt])
  @@map("nfc_token_audit_logs")
}

// NFC Token Authorization - tracks HCE tap authorizations
model NfcTokenAuthorization {
  id              String    @id @default(uuid())
  tokenId         String    @map("token_id")
  token           NfcToken  @relation(fields: [tokenId], references: [id])
  
  cpoPartyId      String    @map("cpo_party_id")
  cpoCountryCode  String    @map("cpo_country_code")
  locationId      String?   @map("location_id")
  evseUid         String?   @map("evse_uid")
  
  result          String    // ALLOWED, BLOCKED, EXPIRED, NO_CREDIT, NOT_ALLOWED, UNKNOWN
  responseTime    Int?      @map("response_time")
  
  // HCE specific
  tapMethod       String    @default("HCE") @map("tap_method") // HCE, SIMULATED
  
  createdAt       DateTime  @default(now()) @map("created_at")

  @@index([tokenId])
  @@index([createdAt])
  @@map("nfc_token_authorizations")
}

// Favorite stations saved by users
model FavoriteStation {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  stationId String   @map("station_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  station   Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, stationId])
  @@index([userId])
  @@map("favorite_stations")
}

// One-time availability alert requests
model AvailabilityAlertRequest {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  stationId String   @map("station_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  station   Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([userId, stationId])
  @@index([stationId])
  @@map("availability_alert_requests")
}

// Notification preferences per user
model NotificationPreference {
  id                     String   @id @default(uuid())
  userId                 String   @unique @map("user_id")
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionUpdatesEnabled  Boolean  @default(true) @map("session_updates_enabled")
  penaltyAlertsEnabled   Boolean  @default(true) @map("penalty_alerts_enabled")
  paymentEnabled         Boolean  @default(true) @map("payment_enabled")
  costMilestonesEnabled      Boolean  @default(false) @map("cost_milestones_enabled")
  costMilestoneIntervalCents Int      @default(500) @map("cost_milestone_interval_cents")
  penaltyPrealertMinutes     Int      @default(5) @map("penalty_prealert_minutes")
  createdAt              DateTime @default(now()) @map("created_at")
  updatedAt              DateTime @updatedAt @map("updated_at")

  @@map("notification_preferences")
}