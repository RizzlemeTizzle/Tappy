{
  "expo": {
    "name": "Tappy Charge",
    "slug": "tappycharge",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tappycharge",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tappycharge.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Find nearby charging stations",
        "NSLocationAlwaysUsageDescription": "Navigate to charging stations",
        "NSCameraUsageDescription": "Scan QR codes to start charging"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "package": "com.tappycharge.app",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "NFC"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "tappycharge.com",
              "pathPrefix": "/start"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0A0A0A"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Find nearby charging stations",
          "locationAlwaysAndWhenInUsePermission": "Navigate to charging stations"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Scan QR codes to start charging"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
