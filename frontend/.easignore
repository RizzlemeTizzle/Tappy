# Use CNG/Prebuild — EAS generates native folders fresh during build
# This also fixes gradle-wrapper.jar missing from git
/android
/ios

# Exclude Metro bundler cache
.metro-cache/

# Exclude backend directories (not needed for frontend build)
../backend/
../backend-node/

# Exclude dev/tooling directories
../.emergent/
../memory/
../test_reports/
../tools/

# Exclude git internals
../.git/
